# AxonAI Supabase / Render environment template.
# Do not commit real secrets. Copy values into Render environment variables.

# Supabase Project Settings > API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Supabase Project Settings > Database > Connection string.
# Prefer the pooled connection string for hosted app servers.
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# Supabase Storage bucket created by supabase/axonai_rehab_schema.sql
AXONAI_SUPABASE_VIDEO_BUCKET=axonai-rehab-videos

# Optional S3-compatible Supabase Storage variables if using the existing
# backend S3 upload path. Fill these only after enabling S3 access in Supabase.
AXONAI_OBJECT_STORAGE_BUCKET=axonai-rehab-videos
AXONAI_OBJECT_STORAGE_ENDPOINT_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/s3
AXONAI_OBJECT_STORAGE_REGION=YOUR_SUPABASE_REGION
AXONAI_OBJECT_STORAGE_ACCESS_KEY_ID=YOUR_SUPABASE_S3_ACCESS_KEY_ID
AXONAI_OBJECT_STORAGE_SECRET_ACCESS_KEY=YOUR_SUPABASE_S3_SECRET_ACCESS_KEY
AXONAI_OBJECT_STORAGE_PUBLIC_BASE_URL=

# Render/runtime settings
AXONAI_UPLOAD_ROOT=/tmp/axonai/uploads
AXONAI_KEEP_UPLOADED_VIDEOS=false

# Expo app
EXPO_PUBLIC_AXONAI_API_URL=https://YOUR_RENDER_SERVICE.onrender.com
